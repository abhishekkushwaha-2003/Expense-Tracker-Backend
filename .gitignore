.idea/
*.iml
*.iws
*.ipr
.settings/
.project
.classpath
.factorypath
.springBeans
.sts4-cache
.vscode/

# --- Local Config & Secrets (Never Deploy These) ---
.env
.env.local
application-*.properties
application-*.yml
# Exception: Keep the base config files
!application.properties
!application.yml

