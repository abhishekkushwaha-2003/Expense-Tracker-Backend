# --- Build Artifacts ---
target/
build/
out/
bin/
*.jar
*.war
*.ear
*.class

# --- KEEP Build Wrappers (Necessary for Deployment) ---
!mvnw
!mvnw.cmd
!.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties

!gradlew
!gradlew.bat
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

